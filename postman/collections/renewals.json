{
  "_postman_id": "renewals-collection-001",
  "name": "Renewals",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Create Plan for Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Renewal Test Plan\", \"cycle\": \"monthly\", \"base_price\": 2900}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "plans", ""]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set(\"plan_id\", res.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Subscription for Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"external_user_id\": \"user_renewal_test\", \"plan_id\": {{plan_id}}}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscriptions/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subscriptions", ""]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{api_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set(\"subscription_id\", res.id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Batch Process Renewals",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/renewals/admin/process?grace_period_days=7",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "renewals", "admin", "process"],
              "query": [
                {
                  "key": "grace_period_days",
                  "value": "7"
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has processed_count\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('processed_count');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Mark Renewal Success",
          "request": {
            "method": "POST",
