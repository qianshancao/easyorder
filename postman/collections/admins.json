{
  "_postman_id": "admins-collection-002",
  "name": "Admins",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
  "auth": {
    "type": "bearer",
    "bearer": [
      {"key": "token", "value": "{{admin_token}}", "type": "string"}
    ]
  },
  "item": [
    {
      "name": "Create Admin",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"newman_admin_{{$randomInt}}\", \"password\": \"pass123\", \"display_name\": \"Test Admin\", \"role\": \"admin\"}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/admins/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admins", ""]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 201 or 409\", () => {",
              "    pm.expect([201, 409]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 201) {",
              "    const res = pm.response.json();",
              "    pm.environment.set(\"admin_id\", res.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "List Admins",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/admins/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admins", ""]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response is array\", () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Admin",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/admins/{{admin_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admins", "{{admin_id}}"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"ID matches admin_id\", () => pm.expect(res.id).to.eql(pm.environment.get(\"admin_id\")));"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Admin",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"display_name\": \"Updated Admin\"}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/admins/{{admin_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admins", "{{admin_id}}"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Change Password",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"old_password\": \"pass123\", \"new_password\": \"newpass456\"}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/admins/{{admin_id}}/password",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "admins", "{{admin_id}}", "password"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    }
  ]
}
