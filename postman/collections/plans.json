{
  "_postman_id": "plans-collection-003",
  "name": "Plans",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
  "item": [
    {
      "name": "Create Plan",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.set('requestStartTime', new Date().toISOString());",
              "pm.environment.set('traceStartUs', Date.now() * 1000);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ========== Layer 1: HTTP Assertions ========",
              "const res = pm.response.json();",
              "",
              "pm.test('[HTTP] Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('[HTTP] Response has id (number)', function () {",
              "    pm.expect(res.id).to.be.a('number');",
              "});",
              "pm.test('[HTTP] Response has correct name', function () {",
              "    pm.expect(res.name).to.eql('Basic Plan');",
              "});",
              "pm.test('[HTTP] Response has correct cycle', function () {",
              "    pm.expect(res.cycle).to.eql('monthly');",
              "});",
              "pm.test('[HTTP] Response has correct base_price', function () {",
              "    pm.expect(res.base_price).to.eql(2900);",
              "});",
              "pm.test('[HTTP] Response status is active', function () {",
              "    pm.expect(res.status).to.eql('active');",
              "});",
              "pm.test('[HTTP] Response has created_at (string)', function () {",
              "    pm.expect(res.created_at).to.be.a('string');",
              "});",
              "",
              "// Variable extraction",
              "pm.environment.set('plan_id', res.id);",
              "",
              "// ========== Layer 2 & 3: Trace + Log Assertions (delayed for OTEL batch flush) ========",
              "const vtUrl = pm.environment.get('observability_url') + ':9428';",
              "const vlUrl = pm.environment.get('observability_url') + ':9429';",
              "const traceStart = Number(pm.environment.get('traceStartUs')) - 5000000;",
              "const traceEnd = Date.now() * 1000 + 60000000;",
              "",
              "setTimeout(function () {",
              "    // ========== Layer 2: Trace Assertions ========",
              "    pm.sendRequest({",
              "        url: vtUrl + '/select/jaeger/api/traces?service=easyorder&start=' + traceStart + '&end=' + traceEnd + '&limit=5',",
              "        method: 'GET'",
              "    }, function (err, resp) {",
              "        if (err) { console.log('[TRACE] Query error: ' + err); return; }",
              "        const data = resp.json();",
              "        const traces = (data.data || []).filter(function (t) {",
              "            return (t.spans || []).some(function (s) {",
              "                return s.operationName && s.operationName.indexOf('POST') !== -1 && s.operationName.indexOf('/plans') !== -1;",
              "            });",
              "        });",
              "",
              "        pm.test('[TRACE] Trace found for POST /api/v1/plans/', function () {",
              "            pm.expect(traces.length).to.be.above(0);",
              "        });",
              "",
              "        if (traces.length > 0) {",
              "            const spans = traces[0].spans || [];",
              "            const httpSpan = spans.find(function (s) {",
              "                return s.operationName && s.operationName.indexOf('POST') === 0;",
              "            });",
              "            if (httpSpan) {",
              "                const getTag = function (key) {",
              "                    const t = (httpSpan.tags || []).find(function (tag) { return tag.key === key; });",
              "                    return t ? t.value : undefined;",
              "                };",
              "                pm.test('[TRACE] Span has http.method = POST', function () {",
              "                    pm.expect(getTag('http.method')).to.eql('POST');",
              "                });",
              "                pm.test('[TRACE] Span has http.status_code = 201', function () {",
              "                    pm.expect(Number(getTag('http.status_code'))).to.eql(201);",
              "                });",
              "            }",
              "            const errorSpans = spans.filter(function (s) {",
              "                const t = (s.tags || []).find(function (tag) { return tag.key === 'otel.status_code'; });",
              "                return t && t.value === 'ERROR';",
              "            });",
              "            pm.test('[TRACE] No error spans in trace', function () {",
              "                pm.expect(errorSpans.length).to.eql(0);",
              "            });",
              "        }",
              "    });",
              "",
              "    // ========== Layer 3: Log Assertions ========",
              "    pm.sendRequest({",
              "        url: vlUrl + '/select/logsql/query',",
              "        method: 'POST',",
              "        header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
              "        body: {",
              "            mode: 'urlencoded',",
              "            urlencoded: [",
              "                { key: 'query', value: '_msg:=\"plan.created\"', type: 'text' },",
              "                { key: 'limit', value: '10', type: 'text' }",
              "            ]",
              "        }",
              "    }, function (err, resp) {",
              "        if (err) { console.log('[LOG] Query error: ' + err); return; }",
              "        const text = resp.text();",
              "        if (!text || !text.trim()) {",
              "            pm.test('[LOG] Event plan.created found', function () {",
              "                pm.expect(false).to.be.true;",
              "            });",
              "            return;",
              "        }",
              "        const logs = text.trim().split('\\n').filter(function (l) { return l; }).map(function (l) {",
              "            try { return JSON.parse(l); } catch (e) { return null; }",
              "        }).filter(Boolean);",
              "",
              "        pm.test('[LOG] Event plan.created found', function () {",
              "            pm.expect(logs.length).to.be.above(0);",
              "        });",
              "        if (logs.length > 0) {",
              "            const log = logs[0];",
              "            pm.test('[LOG] Event has plan_id field', function () {",
              "                pm.expect(log.plan_id).to.be.ok;",
              "            });",
              "            pm.test('[LOG] Event has plan_name field', function () {",
              "                pm.expect(log.plan_name).to.be.ok;",
              "            });",
              "            pm.test('[LOG] Event has cycle field', function () {",
              "                pm.expect(log.cycle).to.be.ok;",
              "            });",
              "        }",
              "    });",
              "}, 6000);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{admin_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Basic Plan\", \"cycle\": \"monthly\", \"base_price\": 2900}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/plans/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "plans", ""]
        }
      },
      "response": []
    },
    {
