              "                pm.test('[TRACE] Span has http.status_code = 200', function () {",
              "                    pm.expect(Number(getTag('http.status_code'))).to.eql(200);",
              "                });",
              "            }",
              "            const errorSpans = spans.filter(function (s) {",
              "                const t = (s.tags || []).find(function (tag) { return tag.key === 'otel.status_code'; });",
              "                return t && t.value === 'ERROR';",
