{
  "_postman_id": "plans-collection-003",
  "name": "Plans",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
  "item": [
    {
      "name": "Create Plan",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{admin_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\": \"Basic Plan\", \"cycle\": \"monthly\", \"base_price\": 2900}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/plans/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "plans", ""]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.environment.set(\"plan_id\", res.id);",
              "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));"
            ]
          }
        }
      ]
    },
    {
      "name": "List Plans",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{api_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/plans/",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "plans", ""]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"Response is array\", () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Plan",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{api_token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/plans/{{plan_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "plans", "{{plan_id}}"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    }
  ]
}
