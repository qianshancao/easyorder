              "            pm.test('[TRACE] No error spans in trace', function () {",
              "                pm.expect(errorSpans.length).to.eql(0);",
              "            });",
              "        }",
              "    });",
              "",
              "    // ========== Layer 3: Log Assertions ========",
              "    pm.sendRequest({",
              "        url: vlUrl + '/select/logsql/query',",
              "        method: 'POST',",
              "        header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
              "        body: {",
              "            mode: 'urlencoded',",
              "            urlencoded: [",
              "                { key: 'query', value: '_msg:=\"plan.listed\"', type: 'text' },",
              "                { key: 'limit', value: '10', type: 'text' }",
              "            ]",
              "        }",
              "    }, function (err, resp) {",
              "        if (err) { console.log('[LOG] Query error: ' + err); return; }",
              "        const text = resp.text();",
              "        if (!text || !text.trim()) {",
              "            pm.test('[LOG] Event plan.listed found', function () {",
              "                pm.expect(false).to.be.true;",
              "            });",
              "            return;",
              "        }",
              "        const logs = text.trim().split('\\n').filter(function (l) { return l; }).map(function (l) {",
              "            try { return JSON.parse(l); } catch (e) { return null; }",
              "        }).filter(Boolean);",
              "",
              "        pm.test('[LOG] Event plan.listed found', function () {",
              "            pm.expect(logs.length).to.be.above(0);",
              "        });",
              "        if (logs.length > 0) {",
              "            const log = logs[0];",
              "            pm.test('[LOG] Event has count field (number)', function () {",
              "                pm.expect(log.count).to.be.a('number');",
              "            });",
              "            pm.test('[LOG] count >= 1', function () {",
              "                pm.expect(log.count).to.be.at.least(1);",
              "            });",
              "        }",
