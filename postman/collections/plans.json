              "",
              "        if (traces.length > 0) {",
              "            const spans = traces[0].spans || [];",
              "            const httpSpan = spans.find(function (s) {",
              "                return s.operationName && s.operationName.indexOf('GET') === 0 && s.operationName.indexOf('/plans') !== -1;",
              "            });",
              "            if (httpSpan) {",
              "                const getTag = function (key) {",
              "                    const t = (httpSpan.tags || []).find(function (tag) { return tag.key === key; });",
              "                    return t ? t.value : undefined;",
              "                };",
              "                pm.test('[TRACE] Span has http.method = GET', function () {",
              "                    pm.expect(getTag('http.method')).to.eql('GET');",
