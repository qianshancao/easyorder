      "name": "Setup",
      "item": [
        {
          "name": "Create Basic Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Basic Plan\", \"cycle\": \"monthly\", \"base_price\": 2900}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plans/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "plans", ""]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set(\"plan_id\", res.id);"
                ]
              }
            }
          ]
        },
